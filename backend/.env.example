# typing-trainer backend — example env
# Скопируй в .env и заполни значения. НИКОГДА не коммить .env!

# ─── App ───────────────────────────────────────────────────────────────
APP_NAME=typing-trainer
APP_ENV=dev              # dev | staging | prod
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG      # DEBUG | INFO | WARNING | ERROR
APP_VERSION=0.1.0

# ─── HTTP ──────────────────────────────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
HTTP_CORS_ORIGINS=["http://localhost:8001","http://localhost:8000"]

# ─── PostgreSQL ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=typing_trainer
DB_USER=tt_user
DB_PASSWORD=changeme_local_only
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── Security ──────────────────────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=changeme_use_token_urlsafe_64
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_ALGORITHM=HS256
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false      # true в prod (HTTPS only)

# ─── Email (Yandex 360 SMTP — T1) ──────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=noreply@typing-trainer.ru
SMTP_PASSWORD=changeme
SMTP_USE_TLS=true
SMTP_FROM=typing-trainer <noreply@typing-trainer.ru>

# ─── OAuth (Sprint 2) ──────────────────────────────────────────────────
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
VK_OAUTH_CLIENT_ID=
VK_OAUTH_CLIENT_SECRET=

# ─── YooKassa (Sprint 6) ───────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_TEST_MODE=true

# ─── Free tier limits (ADR-based) ──────────────────────────────────────
FREE_LESSON_LIMIT=5                        # ADR/PRD Q1
ANONYMOUS_TTL_DAYS=3                       # ADR-001
FAMILY_MAX_SUBACCOUNTS=4                   # ADR-003

# ─── Rate limits ───────────────────────────────────────────────────────
RATE_LIMIT_SIGNUP_PER_HOUR=3
RATE_LIMIT_SIGNIN_PER_MINUTE=5
RATE_LIMIT_PROGRESS_PER_MINUTE=60

# ─── Yandex SmartCaptcha (Sprint 1, R-007 mitigation) ──────────────────
# Регистрация: https://cloud.yandex.ru/services/smartcaptcha (бесплатно до 10K/мес)
YANDEX_CAPTCHA_SITE_KEY=                  # для frontend (public key)
YANDEX_CAPTCHA_SERVER_KEY=                # для backend (secret key)
YANDEX_CAPTCHA_FALLBACK_MODE=fail-closed  # 'fail-closed' для prod, 'fail-open' можно в dev
