# OS / editor debris
.DS_Store
Thumbs.db
nul
*.swp
*~

# Test output (E2E screenshots)
verify-screenshots/
verify-screenshots-local/
scripts/screenshots/

# Python bytecode (генерят локальные прогоны verify-скриптов и compileall в CI)
__pycache__/
*.pyc

# Local-only artifacts
# - error/ contains bug-report screenshots collected locally
# - docs/temp/ holds workshop scratch
error/
docs/temp/

# Build / dist (no build system yet, but reserve)
node_modules/
dist/
build/

# Local IDE
.vscode/
.idea/

# Claude Code session state (per-machine — settings only;
# .claude/agents/ и .claude/SESSION_CONTEXT.md трекаем как командные)
.claude/settings.local.json

# Large binary assets — keep .txt extracted versions instead
# (.doc файл «Соло на пишущей машинке 1992» — 12MB, исходник из docs/book/)
docs/book/*.doc
docs/book/*.docx

# Дизайн-handoff содержит дублирующие .zip-архивы — нам нужны только
# распакованные jsx-референсы из них. Игнорируем все zip (любая папка handoff).
*.zip
