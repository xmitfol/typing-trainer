  "finger_focus": "< > / \" combo for HTML",
  "tips": [
    {
      "type": "lead",
      "text": "A tag opens with < and closes with >. Markup is unforgiving - a missing bracket and the whole line falls apart."
    },
    {
      "type": "drop",
      "text": "The attributes live inside: class=\"box\". Mind the quotes; they have to pair."
    },
    {
      "type": "exercise",
      "target": "<div class=\"box\"><p id=\"main\">Hello, world!</p></div>",
      "finger": "blue",
      "hint": "< > / \" combo for HTML"
    },
    {
      "type": "p",
      "text": "Every tag you open, you close - </tag>. Leave one hanging and the page knows."
    },
    {
      "type": "callout",
      "icon": "💡",
      "title": "Note",
      "text": "A few tags close themselves: <img ... > stands alone, no closing tag needed."
    },
    {
      "type": "exercise",
      "target": "<a href=\"/home\">Home</a> <img src=\"pic.jpg\" alt=\"photo\">",
      "finger": "green",
      "hint": "< > / \" combo for HTML"
    }
  ],
  "character_tips": {
    "anna": "Markup is just structure you can see. The < > / and \" become second nature once you stop fearing them.",
    "maxim": "People who build the web type these brackets all day. Make the shapes automatic.",
    "knopych": "Open the tag, close the tag. Balanced and clean - that's the craft.",
    "klavochka": "Tags wrap the words the way punctuation wraps a sentence. Tidy work, both."
  },
