  "tips": [
    {
      "type": "lead",
      "text": "Take the sentence in with your eyes before your hands move. Reading one letter at a time is how you lose the thread; read the line, then set it down."
    },
    {
      "type": "drop",
      "text": "The space between words is part of the music, not a stop. Glide into it without pausing and the sentence holds together."
    },
    {
      "type": "exercise",
      "target": "the dog and the cat had a sad day",
      "finger": "blue",
      "hint": "All alphabet - sentence rhythm"
    },
    {
      "type": "p",
      "text": "Steady beats fast. A typist who rushes and stops will always lose to one who keeps an even pace."
    },
    {
      "type": "exercise",
      "target": "they tried hard to win at last and were happy",
      "finger": "green",
      "hint": "All alphabet - sentence rhythm"
    }
