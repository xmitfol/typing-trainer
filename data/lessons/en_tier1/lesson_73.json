  "guided": true,
  "tips": [
    {
      "type": "lead",
      "text": "No new keys today. The aim is a clean, even tempo - the kind a report keeps when every sentence pulls its weight. Three plain words, each repeated at one steady pace."
    },
    {
      "type": "drop",
      "text": "Hands on the home row, thumbs over the space bar, eyes off the keys. Repeat each word without hurrying. If the pace slips, count it: one, two, three, four."
    },
    {
      "type": "callout",
      "icon": "metronome",
      "title": "Even hands",
      "text": "Cut the clutter so the point survives - that holds for typing too. Keep one gap between keystrokes and the words come out even. An even hand reads as a confident one, on the page and off it."
    },
    {
      "type": "step",
      "kind": "drill",
      "unit": "revenue",
      "baseReps": 5,
      "keys": ["r", "e", "v", "n", "u"],
      "target": "revenue revenue revenue revenue revenue",
      "finger": "blue",
      "title": "Rhythm: revenue",
      "hint": "Repeat at one tempo: revenue - revenue - revenue. Hold the gaps equal."
    },
    {
      "type": "step",
      "kind": "drill",
      "unit": "targets",
      "baseReps": 4,
      "keys": ["t", "a", "r", "g", "e", "s"],
      "target": "targets targets targets targets",
      "finger": "blue",
      "title": "Rhythm: targets",
      "hint": "Repeat steadily, no jerks: targets - targets - targets."
    },
    {
      "type": "step",
      "kind": "drill",
      "unit": "content",
      "baseReps": 4,
      "keys": ["c", "o", "n", "t", "e"],
      "target": "content content content content",
      "finger": "green",
      "title": "Rhythm: content",
      "hint": "Repeat evenly: content - content - content. Do not speed up at the end."
    },
    {
      "type": "p",
      "text": "Let the hand take each word whole, the way you sign your name without thinking about the letters. Even repetition turns motion into habit - and a habit that holds is what carries a long report to its last line."
    },
    {
      "type": "pullquote",
      "text": "Loosen your shoulders, picture the metronome, and let rhythm set the pace. Tempo before speed, always.",
      "by": "Eleanor Hayes, editor"
    },
    {
      "type": "p",
      "text": "All three done? Open the trainer below and take one clean run at the full lesson text. That run saves your progress and unlocks the next lesson."
    }
  ],
