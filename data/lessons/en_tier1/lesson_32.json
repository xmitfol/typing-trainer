  "finger_focus": "Left Shift held by pinky; right hand types 6-0 with own fingers",
  "tips": [
    {
      "type": "lead",
      "text": "Five more symbols on the upper floor, this time over the right half of the number row: the caret, the ampersand, the star, and the pair of parentheses. You will reach for the brackets most - they hold an aside together, in copy and in code alike."
    },
    {
      "type": "drop",
      "text": "All five are Shift plus a digit. ^ is Shift+6, & is Shift+7, * is Shift+8, ( is Shift+9, ) is Shift+0. The digits sit on the right, so this time the left pinky holds Shift while the right hand strikes."
    },
    {
      "type": "callout",
      "icon": "keyboard",
      "title": "Mind the opposite hand",
      "text": "Left Shift, right hand. Parentheses come in pairs - open one and you owe a close. An unclosed bracket is a loose end, and loose ends get noticed."
    },
    {
      "type": "step",
      "kind": "drill",
      "target": "^ ^ ^ & & & * * * ^ & * ^ & *",
      "finger": "pink",
      "title": "Caret, ampersand, star",
      "hint": "^ is Shift+6, & is Shift+7, * is Shift+8. Left pinky holds Shift."
    },
    {
      "type": "step",
      "kind": "drill",
      "target": "( ) ( ) (a) (b) (cd) ( ) ( )",
      "finger": "orange",
      "title": "Open and close",
      "hint": "( is Shift+9, ) is Shift+0. Every open bracket gets its close."
    },
    {
      "type": "step",
      "kind": "drill",
      "target": "2^3 = 8. 3*5 = 15. f(x) = y. a & b.",
      "finger": "green",
      "title": "Math and code",
      "hint": "Caret for a power, star for a product, parentheses around the function."
    },
    {
      "type": "p",
      "text": "These earn their keep in formulas and in code: a power, a product, a function wrapped in parentheses, an ampersand joining two things. Set them down cleanly and the line reads itself."
    }
  ],
  "character_tips": {
    "anna": "Right-side Shift symbols - use LEFT Shift, right-hand digits.",
    "maxim": "Parentheses ( ) are everywhere - math, code, English. Master them.",
    "knopych": "PAREN POWER! ( open ) close ⚡",
    "klavochka": "Brackets hug ideas - like a gentle embrace 🤗"
