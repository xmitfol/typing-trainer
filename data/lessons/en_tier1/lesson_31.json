  "finger_focus": "Right Shift held by pinky; left hand types 1-5 with own pinky/ring/middle/index",
  "tips": [
    {
      "type": "lead",
      "text": "You already know the number row. These four symbols live one floor up, reached with Shift: the at sign, the hash, the dollar, the percent. An editor meets them every day - in an address line, a tag, a price, a figure. Learn them properly and you stop hunting."
    },
    {
      "type": "drop",
      "text": "Each one is Shift plus a digit. @ is Shift+2, # is Shift+3, $ is Shift+4, % is Shift+5. The same finger that owns the digit owns the symbol above it; the opposite pinky holds Shift. These four sit on the left half, so hold the right Shift."
    },
    {
      "type": "callout",
      "icon": "keyboard",
      "title": "One rule, four symbols",
      "text": "Right pinky holds Shift; the left hand strikes the digit. Keep your eyes on the line, not on your hands. If you look down, you lose the thought."
    },
    {
      "type": "step",
      "kind": "drill",
      "target": "@ @ @ # # # @ # @ # @ #",
      "finger": "pink",
      "title": "At and hash",
      "hint": "@ is Shift+2, # is Shift+3. Right pinky on Shift, left hand on the digit."
    },
    {
      "type": "step",
      "kind": "drill",
      "target": "$ $ $ % % % $ % $ % $ %",
      "finger": "pink",
      "title": "Dollar and percent",
      "hint": "$ is Shift+4, % is Shift+5. A space after each one, steady and even."
    },
    {
      "type": "step",
      "kind": "drill",
      "target": "alex@site.com #billing $100 at 50% rate",
      "finger": "green",
      "title": "Address, tag, figure",
      "hint": "@ in the address, # on the tag, $ and % on the numbers. Mind the spacing."
    },
    {
      "type": "p",
      "text": "Now put them to work, the way you would in a real line of copy. The at sign points an address, the hash marks a tag, the dollar leads a price, the percent closes a figure. Accuracy first - the speed will follow."
    }
  ],
  "character_tips": {
    "anna": "Shift symbols on the left side use the right pinky for Shift. Opposite hand rule.",
    "maxim": "Email and price symbols - daily writing needs these. @ and $ especially.",
    "knopych": "SHIFT COMBOS! ! @ # $ % - power keys! ⚡",
    "klavochka": "Special characters open new worlds - like emails and hashtags! 💖"
