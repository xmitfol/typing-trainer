    {
      "type": "lead",
      "text": "Contract prose runs long on purpose. The sentences stretch, the clauses pile up, and you keep an even hand all the way through."
    },
    {
      "type": "drop",
      "text": "Treat a word like \"hereinafter\" as one block, not nine letters. Stamp it whole and the long sentence stops being long."
    },
