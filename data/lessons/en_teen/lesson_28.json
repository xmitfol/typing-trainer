  "tips": [
    {
      "type": "lead",
      "text": "Think of this like a chorus on repeat. No new keys - just loop each word until it plays itself through your fingers. Flow, not force."
    },
    {
      "type": "drop",
      "text": "Hands on home row, eyes off the keys. Repeat each word at one even pace - same gap between every tap, like a beat under a track. Don't rush, just ride it."
    },
    {
      "type": "callout",
      "icon": "🎶",
      "title": "Even beat",
      "text": "Lock a tempo you can hold and stay in the pocket. Speed comes from feel, not effort - smooth and even beats fast and jerky every time."
    },
    {
