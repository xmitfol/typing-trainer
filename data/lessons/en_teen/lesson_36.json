  "tips": [
    {
      "type": "lead",
      "text": "Same energy as scrolling a feed - same word over and over until it stops feeling like work. No new keys, just flow. Flow, not force."
    },
    {
      "type": "drop",
      "text": "Hands on home row, eyes up off the keys. Repeat each word at one even pace - same gap between every tap. Don't sprint, just keep the scroll smooth and steady."
    },
    {
      "type": "callout",
      "icon": "🎶",
      "title": "Even beat",
      "text": "Pick a tempo you can actually hold and stay locked in. Even and smooth beats fast and jerky every single time. Let the rhythm carry your hands."
    },
    {
      "type": "step",
      "kind": "drill",
      "unit": "live",
      "baseReps": 5,
      "keys": ["l", "i", "v", "e"],
      "target": "live live live live live",
      "finger": "orange",
      "title": "Rhythm: live",
      "hint": "Loop it on the beat: live - live - live. Same gap every time."
    },
    {
      "type": "step",
      "kind": "drill",
      "unit": "grind",
      "baseReps": 4,
      "keys": ["g", "r", "i", "n", "d"],
      "target": "grind grind grind grind",
      "finger": "blue",
      "title": "Rhythm: grind",
      "hint": "Hold the tempo: grind - grind - grind. Flow, not force."
    },
    {
      "type": "step",
      "kind": "drill",
      "unit": "only",
      "baseReps": 4,
      "keys": ["o", "n", "l", "y"],
      "target": "only only only only",
      "finger": "orange",
      "title": "Rhythm: only",
      "hint": "Stay even to the end: only - only - only. Don't rush the finish."
    },
    {
      "type": "p",
      "text": "Notice your fingers grabbing the whole word in one smooth move? That is the goal - even reps turn conscious effort into reflex, and reflex is where the speed actually comes from."
    },
